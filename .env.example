# Shared
MONGO_URI=mongodb://mongo:27017/aibot
MONGO_DB=aibot
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
REDIS_URL=redis://redis:6379/0

# OpenAI (for human-like smalltalk / general responses)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Partificial VIN check
VIN_CHECK_URL=https://vin.partificial.ai/api/vin/check
VIN_CHECK_TIMEOUT_S=12
VIN_DEV_TOKEN=

# Partificial parts search
PARTS_SEARCH_URL=https://part.partificial.ai/api/parts/search
PARTS_SEARCH_TIMEOUT_S=20

# TecDoc lookup
TECDOC_SEARCH_OEM_URL=https://tecdoc.partificial.ai/api/tecdoc/search-oem
TECDOC_SEARCH_OEM_TIMEOUT_S=20

# Debug (logs external calls; does NOT print tokens)
DEBUG_EXTERNAL_CALLS=0

# MinIO (S3-compatible)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_BUCKET=chatbot

# WhatsApp Cloud API (optional for local dev)
WA_VERIFY_TOKEN=dev-verify-token
WA_APP_SECRET=
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=
